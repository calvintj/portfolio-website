# Caddy automatically provisions and renews a Let's Encrypt TLS certificate
# for $DOMAIN (set via the DOMAIN env var in docker-compose.prod.yml).
# Certs are persisted in the caddy_data volume so deploys don't re-request them.

{$DOMAIN} {
	encode gzip
	reverse_proxy web:3000
}

# Redirect www -> apex. Uncomment if you also point www at this host:
# www.{$DOMAIN} {
# 	redir https://{$DOMAIN}{uri} permanent
# }
